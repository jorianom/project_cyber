      "source": [
        "## 4 · Preprocessing"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "id": "a09bbd9b",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a09bbd9b",
        "outputId": "a871e7b5-5ac4-4be9-fa3d-6bd2ef0b55cf"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train : 79,908  |  Test : 19,977\n",
            "Class balance — train: 50.1%   test: 50.1%\n",
            "Features : 40\n"
          ]
        }
      ],
      "source": [
        "FEATURE_COLS = [c for c in df_feat.columns if c != TARGET_COL]\n",
        "X = df_feat[FEATURE_COLS]\n",
        "y = df_feat[TARGET_COL]\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=TEST_SIZE, random_state=RANDOM_STATE, stratify=y\n",
        ")\n",
        "\n",
        "preprocessor = Pipeline([\n",
        "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
        "    (\"scaler\",  StandardScaler()),\n",
        "])\n",
        "\n",
        "print(f\"Train : {len(X_train):,}  |  Test : {len(X_test):,}\")\n",
        "print(f\"Class balance — train: {y_train.mean():.1%}   test: {y_test.mean():.1%}\")\n",
        "print(f\"Features : {len(FEATURE_COLS)}\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "97007b35",
